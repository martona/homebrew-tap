{
  "targets": {
    "yo": {
      "kind": "formula",
      "path": "Formula/yo.rb",
      "release_repo": "martona/yo",
      "checksum_asset": "SHA256SUMS.txt",
      "asset_url_template": "https://github.com/{release_repo}/releases/download/{tag}/{file}",
      "assets": [
        {
          "file": "yo-macos-arm64.zip"
        },
        {
          "file": "yo-macos-amd64.zip"
        },
        {
          "file": "yo-linux-amd64"
        },
        {
          "file": "yo-linux-arm64"
        }
      ]
    },
    "gig": {
      "kind": "cask",
      "path": "Casks/gig.rb",
      "release_repo": "martona/gig",
      "checksum_asset": "SHA256SUMS.txt",
      "asset_url_template": "https://github.com/{release_repo}/releases/download/{tag}/{file}",
      "assets": [
        {
          "file": "gig-macos-arm64.zip",
          "update_url": false
        }
      ]
    },
    "clipp": {
      "kind": "cask",
      "path": "Casks/clipp.rb",
      "release_repo": "martona/clipp",
      "checksum_asset": "SHA256SUMS.txt",
      "asset_url_template": "https://github.com/{release_repo}/releases/download/{tag}/{file}",
      "assets": [
        {
          "file": "clipp-macos-arm64.zip",
          "update_url": false
        }
      ]
    }
  }
}
